# Copy this file to .env and customize for your environment
# Usage: cp .env.example .env

# === REQUIRED: Path Configuration ===
# Path to directory containing BOLT3-optimized binary + PA data
PA_BINARY_DIR=/home/youruser/samples
PA_DATA_DIR=/data/pa-data

# === Server Configuration ===
PA_SERVER_NAME=My-PA-Server
PA_PORT=20545
PA_MAX_PLAYERS=10
PA_GAME_MODE=PAExpansion1:lobby

# === Deployment (for deploy.sh) ===
REMOTE_USER=youruser
REMOTE_HOST=192.168.1.100
REMOTE_PATH=/home/youruser/pa-docker
